# .env is generated at deploy time by scripts/deploy.sh from:
#   config.env         — non-sensitive config (committed plaintext)
#   secrets.enc.env    — SOPS-encrypted secrets (committed safe)
# The age private key at keys/age.key decrypts secrets.enc.env on the VPS.
# See DEPLOY.md § secrets management.
#
# LOCAL DEV (no sops): just use the docker compose defaults — no .env needed.
# For a fully local experience: cp config.env .env && use compose defaults
# for the password (visionpass).

# Placeholder values — do NOT edit this file directly.
DATABASE_URL=postgresql://vision:CHANGE_ME@db:5432/vision_template
POSTGRES_PASSWORD=CHANGE_ME
