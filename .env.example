# ---- App ----
# Inside docker compose this points at the `db` service container.
# For local dev (no compose) use: postgresql://localhost:5432/vision_template
DATABASE_URL=postgresql://vision:visionpass@db:5432/vision_template
PORT=3000
NODE_ENV=production

# ---- Postgres (consumed by docker-compose.yml for the db service) ----
POSTGRES_USER=vision
POSTGRES_PASSWORD=visionpass
POSTGRES_DB=vision_template

# ---- Backups (consumed by scripts/backup-db.sh) ----
# How many daily dumps to keep on disk.
BACKUP_KEEP=14
